# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connection Details
# Use the "pooled" connection string for DATABASE_URL
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Use the "direct" (non-pooled) connection string for DIRECT_URL (needed for migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth (next-auth) ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-secure-random-string"
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# ─── Tranzila Payment Gateway ─────────────────────────────────────────────────
TRANZILA_TERMINAL_NAME="your_terminal_name"
TRANZILA_API_KEY="your_api_key"
TRANZILA_WEBHOOK_SECRET="your_webhook_secret"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Football Shop <noreply@footballshop.co.il>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app"
NODE_ENV="production"
